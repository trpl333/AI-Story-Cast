# Supabase (Auth). Copy to `.env.local` and fill from Project Settings → API.
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# FastAPI reader backend (Alice demo chapter). Default in code is http://127.0.0.1:8000 if unset.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: n8n webhook that proxies public-domain search (Gutenberg via Gutendex). When unset, Library search uses the starter catalog only.
# VITE_AISTORYCAST_SEARCH_URL=https://your-n8n.example/webhook/aistorycast-search-books
